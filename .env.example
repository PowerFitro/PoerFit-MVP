# ============================================
# PowerFit MVP - Environment Variables
# ============================================
# Copiază acest fișier ca .env și completează valorile

# --- Supabase ---
# Ia-le din: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# --- Telegram Bot ---
# Creează bot-ul cu @BotFather pe Telegram
# Comanda: /newbot → numele: PowerFit Coach → username: PowerFitCoachBot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# --- ID-ul chat-ului admin (antrenorul) ---
# Trimite un mesaj bot-ului, apoi accesează:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Copiază "chat.id" din răspuns
TELEGRAM_ADMIN_CHAT_ID=123456789

# --- Anthropic (Claude AI) ---
# Ia-l din: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Email (opțional pentru MVP, adaugă mai târziu) ---
# RESEND_API_KEY=re_...
